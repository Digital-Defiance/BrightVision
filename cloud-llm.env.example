# Copy to cloud-llm.env (gitignored). LiteLLM reads these when the Vision API starts.
# Do not commit secrets.

# --- Azure OpenAI (portal “OpenAI v1” sample: base_url ends at /openai/v1) ---
# https://brightvision.openai.azure.com/ → endpoint below; model = deployment name.
#
OPENAI_API_KEY=
OPENAI_API_BASE=https://brightvision.openai.azure.com/openai/v1
E2E_VISION_MODEL=openai/gpt-5.3-chat

# Settings → LLM model: same as E2E_VISION_MODEL (openai/gpt-5.3-chat), not ollama_chat/…

# --- Classic Azure SDK layout (only if portal shows azure/<deployment> + api-version) ---
# AZURE_API_KEY=
# AZURE_API_BASE=https://brightvision.openai.azure.com
# AZURE_API_VERSION=2024-12-01-preview
# E2E_VISION_MODEL=azure/gpt-5.3-chat
